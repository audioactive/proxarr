{
  "name": "proxarr",
  "version": "1.0.0",
  "description": "Proxmox *arr stack deployer – one-command LXC deployment tool",
  "type": "module",
  "bin": {
    "proxarr": "./server.js"
  },
  "files": [
    "server.js",
    "dist/**"
  ],
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 vite",
    "build": "vite build",
    "start": "node server.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": ["proxmox", "arr", "sonarr", "radarr", "lxc", "deploy"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/audioactive/proxarr.git"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "8.0.0-beta.18"
  },
  "overrides": {
    "vite": "8.0.0-beta.18"
  }
}
